root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{py,pyi}]
indent_size = 4
max_line_length = 88

[*.dart]
indent_size = 2
max_line_length = 80

[*.{md,mdx}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
