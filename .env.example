# Runtime environment: local, development, staging, or production
NEXTFIGHT_ENV=local
NEXTFIGHT_LOG_LEVEL=DEBUG

# PostgreSQL (local development only)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nextfight
POSTGRES_USER=nextfight
POSTGRES_PASSWORD=local-nextfight-password
DATABASE_URL=postgresql+asyncpg://nextfight:local-nextfight-password@localhost:5432/nextfight

# Redis (local development only)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Authentication (replace with a random secret of at least 32 bytes outside local)
JWT_SECRET=local-development-secret-change-me
PASSWORD_RESET_MINUTES=30
PASSWORD_RESET_URL=http://localhost:5173/reset-password

# SMTP transactional email (required in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Push providers (required in production; never commit credential files or keys)
FCM_CREDENTIALS_PATH=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=app.nextfight.mobile
APNS_PRIVATE_KEY=
APNS_USE_SANDBOX=true
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# Public local endpoints used by future clients
API_BASE_URL=http://localhost:8000/api/v1
WEBSOCKET_BASE_URL=ws://localhost:8000/ws
ADMIN_BASE_URL=http://localhost:5173
BACKEND_PORT=8000
